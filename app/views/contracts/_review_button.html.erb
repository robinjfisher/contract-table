<%= turbo_frame_tag "contract_#{contract.id}_review" do %>
  <%= form_with url: review_project_contract_path(contract.project_id, contract), method: :patch do %>
    <button type="submit"
            title="<%= contract.reviewed? ? 'Mark as not reviewed' : 'Mark as reviewed' %>"
            class="inline-flex items-center gap-1 text-xs transition-colors
                   <%= contract.reviewed? ? 'text-green-600 hover:text-gray-400' : 'text-gray-400 hover:text-green-600 opacity-0 group-hover/row:opacity-100' %>">
      <svg class="h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
      </svg>
      <%= contract.reviewed? ? "Reviewed" : "Mark reviewed" %>
    </button>
  <% end %>
<% end %>
