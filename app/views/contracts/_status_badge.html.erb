<% dot_class, text_class, label = case contract.status
  when "pending"    then ["bg-gray-300",  "text-gray-500",  "Pending"]
  when "processing" then ["bg-amber-400 animate-pulse", "text-amber-700", "Processing"]
  when "done"       then ["bg-emerald-400", "text-emerald-700", "Done"]
  when "error"      then ["bg-red-400",   "text-red-700",   "Error"]
  end %>
<span class="inline-flex items-center gap-1.5">
  <span class="h-1.5 w-1.5 rounded-full <%= dot_class %>"></span>
  <span class="text-xs font-medium <%= text_class %>"><%= label %></span>
</span>
