<%= turbo_frame_tag "contract_preview", class: "flex flex-col flex-1 min-h-0" do %>
  <% if @contract.file.content_type == "application/pdf" %>
    <iframe src="<%= rails_blob_path(@contract.file, disposition: "inline") %>"
            class="flex-1 w-full border-0"
            title="<%= @contract.name %>"></iframe>
  <% else %>
    <div class="flex flex-col items-center justify-center flex-1 gap-3 text-gray-400 p-8">
      <svg class="h-12 w-12" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
      </svg>
      <p class="text-sm">Preview not available for DOCX files.</p>
      <%= link_to "Download file",
            rails_blob_path(@contract.file, disposition: "attachment"),
            class: "text-sm text-blue-600 hover:text-blue-800 font-medium" %>
    </div>
  <% end %>
<% end %>
