<%= turbo_frame_tag "contracts-table" do %>

  <%# Toolbar %>
  <div class="flex items-start justify-between mb-3 gap-4">

    <details class="group/addfield">
      <summary class="cursor-pointer list-none inline-flex items-center gap-1.5 text-sm font-medium text-blue-600 hover:text-blue-800 transition-colors">
        <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Add custom field
      </summary>
      <div class="mt-2 p-4 bg-gray-50 border border-gray-200 rounded-lg">
        <%= form_with url: project_fields_path(project), scope: :field do |f| %>
          <div class="flex gap-3 items-end">
            <div class="flex-1">
              <%= f.label :label, "Field name", class: "block text-xs font-medium text-gray-600 mb-1" %>
              <%= f.text_field :label, placeholder: "e.g. Payment Terms",
                    class: "w-full border border-gray-200 rounded-md px-2.5 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
            </div>
            <div class="flex-[2]">
              <%= f.label :question, "What should Claude extract?", class: "block text-xs font-medium text-gray-600 mb-1" %>
              <%= f.text_field :question, placeholder: "e.g. What are the payment terms?",
                    class: "w-full border border-gray-200 rounded-md px-2.5 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
            </div>
            <div class="shrink-0">
              <%= f.label :field_type, "Type", class: "block text-xs font-medium text-gray-600 mb-1" %>
              <%= f.select :field_type,
                    [["Text", "text"], ["Yes / No", "yes_no"], ["Date", "date"]],
                    {},
                    class: "border border-gray-200 rounded-md px-2.5 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
            </div>
            <%= f.submit "Add field",
                  class: "shrink-0 px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md cursor-pointer transition-colors" %>
          </div>
        <% end %>
      </div>
    </details>

    <div class="flex gap-2 shrink-0 items-center">
      <% if @sort_field&.positive? || @filter_value.present? %>
        <%= link_to "Clear filters", project_path(project),
              class: "inline-flex items-center text-xs font-medium text-amber-600 hover:text-amber-800 border border-amber-200 hover:border-amber-300 rounded-md px-3 py-1.5 transition-colors" %>
      <% end %>
      <%= link_to "Export CSV",
            project_export_path(project, format: :csv),
            class: "inline-flex items-center text-xs font-medium text-gray-500 hover:text-gray-800 border border-gray-200 hover:border-gray-300 rounded-md px-3 py-1.5 transition-colors" %>
      <%= link_to "Export Excel",
            project_export_path(project, format: :xlsx),
            class: "inline-flex items-center text-xs font-medium text-gray-500 hover:text-gray-800 border border-gray-200 hover:border-gray-300 rounded-md px-3 py-1.5 transition-colors" %>
    </div>
  </div>

  <%# Table — scrolls on both axes; header and first column are sticky %>
  <div class="overflow-auto rounded-xl border border-gray-200 max-h-[calc(100vh-16rem)] shadow-sm">
    <table class="w-full table-fixed text-sm border-separate border-spacing-0">
      <colgroup>
        <col class="w-56">
        <col class="w-28">
        <% fields.each do %>
          <col class="w-44">
        <% end %>
      </colgroup>

      <thead>
        <%# Row 1: Column headers with sort links %>
        <tr>
          <%# File column — sticky left + top (corner) %>
          <th scope="col"
              class="sticky left-0 top-0 z-30 bg-gray-50 px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider border-b border-r border-gray-200 whitespace-nowrap">
            File
          </th>
          <%# Status column — sticky top only %>
          <th scope="col"
              class="sticky top-0 z-20 bg-gray-50 px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider border-b border-gray-200 whitespace-nowrap">
            Status
          </th>
          <%# Field columns — sticky top only, with sort links %>
          <% fields.each do |field| %>
            <%
              is_sorted = @sort_field == field.id
              toggle_dir = (is_sorted && @sort_dir == "asc") ? "desc" : "asc"
              sort_params = { sort_field: field.id, sort_dir: toggle_dir }
              sort_params[:filter_field] = @filter_field if @filter_field&.positive?
              sort_params[:filter_value] = @filter_value if @filter_value.present?
            %>
            <th scope="col"
                class="sticky top-0 z-20 bg-gray-50 px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider border-b border-gray-200">
              <div class="flex items-center justify-between gap-1 group/col">
                <%= link_to project_path(project, **sort_params),
                      class: "flex items-center gap-1 truncate hover:text-gray-800 transition-colors #{is_sorted ? 'text-blue-600' : ''}" do %>
                  <%# Type indicator icon %>
                  <% if field.field_type == "date" %>
                    <svg class="h-3 w-3 shrink-0 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" title="Date field">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                    </svg>
                  <% elsif field.field_type == "yes_no" %>
                    <svg class="h-3 w-3 shrink-0 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" title="Yes/No field">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 8.689c0-.864.933-1.406 1.683-.977l7.108 4.061a1.125 1.125 0 0 1 0 1.954l-7.108 4.061A1.125 1.125 0 0 1 3 16.811V8.69ZM12.75 8.689c0-.864.933-1.406 1.683-.977l7.108 4.061a1.125 1.125 0 0 1 0 1.954l-7.108 4.061a1.125 1.125 0 0 1-1.683-.977V8.69Z" />
                    </svg>
                  <% end %>
                  <span class="truncate"><%= field.label %></span>
                  <% if is_sorted %>
                    <% if @sort_dir == "asc" %>
                      <%# Chevron up %>
                      <svg class="h-3 w-3 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 15.75 7.5-7.5 7.5 7.5" />
                      </svg>
                    <% else %>
                      <%# Chevron down %>
                      <svg class="h-3 w-3 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                      </svg>
                    <% end %>
                  <% else %>
                    <%# Inactive sort indicator (faint) %>
                    <svg class="h-3 w-3 shrink-0 opacity-0 group-hover/col:opacity-30 transition-opacity" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 15.75 7.5-7.5 7.5 7.5" />
                    </svg>
                  <% end %>
                <% end %>
                <%= form_with url: project_field_path(project, field), method: :delete, class: "shrink-0" do %>
                  <button type="submit"
                          title="Remove <%= field.label %>"
                          class="opacity-0 group-hover/col:opacity-100 transition-opacity text-gray-300 hover:text-red-500 text-base leading-none font-normal">
                    &times;
                  </button>
                <% end %>
              </div>
            </th>
          <% end %>
        </tr>

        <%# Row 2: Filter inputs %>
        <tr>
          <th class="sticky left-0 z-30 bg-gray-50 px-3 py-1.5 border-b border-r border-gray-200"></th>
          <th class="z-20 bg-gray-50 px-3 py-1.5 border-b border-gray-200"></th>
          <% fields.each do |field| %>
            <th class="z-20 bg-gray-50 px-3 py-1.5 border-b border-gray-200">
              <%= form_with url: project_path(project), method: :get, data: { controller: "filter" } do |f| %>
                <% if @sort_field&.positive? %>
                  <%= f.hidden_field :sort_field, value: @sort_field %>
                  <%= f.hidden_field :sort_dir, value: @sort_dir %>
                <% end %>
                <%= f.hidden_field :filter_field, value: field.id %>
                <%= f.text_field :filter_value,
                      value: (@filter_field == field.id ? @filter_value : nil),
                      placeholder: "Filter…",
                      autocomplete: "off",
                      data: { action: "input->filter#debouncedSubmit" },
                      class: "w-full border rounded px-2 py-1 text-xs font-normal focus:outline-none focus:ring-1 focus:ring-blue-500 placeholder-gray-300 transition-colors
                              #{@filter_field == field.id && @filter_value.present? ? 'border-blue-400 bg-blue-50' : 'border-gray-200 bg-white'}" %>
              <% end %>
            </th>
          <% end %>
        </tr>
      </thead>

      <tbody id="contracts" class="bg-white">
        <% if contracts.empty? %>
          <tr id="contracts-empty-state">
            <td colspan="<%= 2 + fields.size %>"
                class="px-4 py-16 text-center text-sm text-gray-400">
              No contracts yet — upload one to get started.
            </td>
          </tr>
        <% else %>
          <%= render partial: "contracts/contract", collection: contracts, locals: { fields: fields } %>
        <% end %>
      </tbody>
    </table>
  </div>

<% end %>
