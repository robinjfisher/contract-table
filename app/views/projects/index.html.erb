<div class="max-w-6xl">

  <div class="flex items-end justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Projects</h1>
      <p class="text-sm text-gray-500 mt-1">Organise and analyse contracts with AI extraction</p>
    </div>
    <%= link_to new_project_path,
          class: "inline-flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors shadow-sm" do %>
      <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      New Project
    <% end %>
  </div>

  <% if @projects.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @projects.each do |project| %>
        <% contracts = project.contracts %>
        <% done_count       = contracts.count { |c| c.status == "done" } %>
        <% processing_count = contracts.count { |c| c.status == "processing" || c.status == "pending" } %>
        <% error_count      = contracts.count { |c| c.status == "error" } %>

        <%= link_to project,
              class: "group flex flex-col bg-white rounded-xl border border-gray-200 p-6 hover:border-blue-200 hover:shadow-md transition-all duration-200" do %>

          <div class="flex items-start justify-between gap-3 mb-4">
            <div class="h-10 w-10 rounded-lg bg-blue-50 flex items-center justify-center shrink-0">
              <svg class="h-5 w-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75h15A2.25 2.25 0 0 1 21.75 12v.75m-8.69-6.44-2.12-2.12a1.5 1.5 0 0 0-1.061-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.379a1.5 1.5 0 0 1-1.06-.44Z" />
              </svg>
            </div>
            <svg class="h-4 w-4 text-gray-300 group-hover:text-blue-400 transition-colors mt-1 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
          </div>

          <h2 class="text-base font-semibold text-gray-900 group-hover:text-blue-600 transition-colors leading-snug">
            <%= project.name %>
          </h2>
          <p class="text-sm text-gray-500 mt-1">
            <%= contracts.count %> <%= "contract".pluralize(contracts.count) %>
          </p>

          <% if contracts.any? %>
            <div class="mt-4 pt-4 border-t border-gray-100 flex items-center gap-3 flex-wrap">
              <% if done_count > 0 %>
                <span class="inline-flex items-center gap-1 text-xs text-emerald-700">
                  <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
                  <%= done_count %> done
                </span>
              <% end %>
              <% if processing_count > 0 %>
                <span class="inline-flex items-center gap-1 text-xs text-amber-700">
                  <span class="h-1.5 w-1.5 rounded-full bg-amber-400"></span>
                  <%= processing_count %> processing
                </span>
              <% end %>
              <% if error_count > 0 %>
                <span class="inline-flex items-center gap-1 text-xs text-red-700">
                  <span class="h-1.5 w-1.5 rounded-full bg-red-400"></span>
                  <%= error_count %> error
                </span>
              <% end %>
            </div>
          <% end %>

        <% end %>
      <% end %>
    </div>

  <% else %>
    <%# Empty state %>
    <div class="flex flex-col items-center justify-center py-24 text-center">
      <div class="h-16 w-16 rounded-2xl bg-blue-50 flex items-center justify-center mb-5">
        <svg class="h-8 w-8 text-blue-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
        </svg>
      </div>
      <h3 class="text-base font-semibold text-gray-900">No projects yet</h3>
      <p class="text-sm text-gray-500 mt-2 max-w-xs">
        Create a project to start uploading contracts and extracting key information with AI.
      </p>
      <%= link_to "Create your first project", new_project_path,
            class: "mt-5 inline-flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors" %>
    </div>
  <% end %>

</div>
