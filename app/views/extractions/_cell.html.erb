<% project_id = local_assigns.fetch(:project_id) { extraction.contract.project_id } %>
<%= turbo_frame_tag "extraction_#{extraction.contract_id}_#{extraction.field_id}" do %>
  <div data-controller="cell" class="group/cell relative">
    <%# Display mode %>
    <div data-cell-target="display"
         data-action="click->cell#edit"
         class="cursor-pointer min-h-5 rounded px-1 -mx-1 hover:bg-gray-50 transition-colors">
      <% if extraction.value.present? %>
        <% case extraction.field.field_type %>
        <% when "yes_no" %>
          <%
            leading       = extraction.value.match(/\A(Yes|No)\b/i)&.to_s
            qualification = extraction.value.sub(/\A(Yes|No)[[:space:]–\-]*/i, "").strip
            badge_class   = leading&.downcase == "yes" ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800"
          %>
          <span class="inline-flex items-baseline flex-wrap gap-x-1.5">
            <% if leading.present? %>
              <span class="inline-block px-1.5 py-0.5 rounded text-xs font-medium <%= badge_class %>"><%= leading %></span>
            <% else %>
              <span class="inline-block px-1.5 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600"><%= extraction.value %></span>
            <% end %>
            <% if qualification.present? %>
              <span class="text-xs text-gray-500 line-clamp-2"><%= qualification %></span>
            <% end %>
          </span>
        <% when "date" %>
          <span class="font-mono text-gray-900 tabular-nums"><%= extraction.value %></span>
        <% else %>
          <span class="text-gray-900 line-clamp-3"><%= extraction.value %></span>
        <% end %>
        <% if extraction.manually_edited? %>
          <span class="text-blue-400 text-xs ml-1" title="Manually edited">✎</span>
        <% end %>
      <% else %>
        <span class="text-gray-300">–</span>
      <% end %>
    </div>

    <%# Hover icons — source (right-0) and annotation (right-4 when source present, else right-0) %>
    <% has_source     = extraction.source_text.present? %>
    <% has_annotation = extraction.annotation.present? %>
    <% note_right     = has_source ? "right-4" : "right-0" %>

    <%# Annotation icon / filled indicator %>
    <%= link_to project_extraction_path(project_id, extraction),
                data: { turbo_frame: "source_panel", action: "panel#open" },
                class: "absolute top-0 #{note_right} p-0.5 transition-opacity
                        #{has_annotation ? 'text-blue-500 opacity-100' : 'text-gray-300 hover:text-blue-500 opacity-0 group-hover/cell:opacity-100'}",
                title: has_annotation ? "View note" : "Add note" do %>
      <svg class="h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" fill="<%= has_annotation ? 'currentColor' : 'none' %>" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 0 1 .865-.501 48.172 48.172 0 0 0 3.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
      </svg>
    <% end %>

    <%# View source icon (hover, only when source is available) %>
    <% if has_source %>
      <%= link_to project_extraction_path(project_id, extraction),
                  data: { turbo_frame: "source_panel", action: "panel#open" },
                  class: "absolute top-0 right-0 p-0.5 text-gray-300 hover:text-blue-500 opacity-0 group-hover/cell:opacity-100 transition-opacity",
                  title: "View source" do %>
        <svg class="h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
        </svg>
      <% end %>
    <% end %>

    <%# Edit mode %>
    <%= form_with url: project_extraction_path(project_id, extraction),
                  method: :patch,
                  scope: :extraction,
                  class: "hidden",
                  data: { cell_target: "form" } do |f| %>
      <%= f.text_field :value,
            value: extraction.value,
            class: "w-full border border-blue-400 rounded px-1.5 py-0.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500",
            data: { cell_target: "input",
                    action: "blur->cell#submit keydown.enter->cell#submit keydown.escape->cell#cancel" } %>
    <% end %>
  </div>
<% end %>
